<Window x:Class="CybersecurityChatbotWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot"
        Height="650" Width="850"
        MinHeight="500" MinWidth="600"
        Background="#F0F0F0"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto" MinHeight="102.6"/>
            <RowDefinition Height="Auto" MinHeight="38.63"/>
        </Grid.RowDefinitions>

        <!-- Header with ASCII Logo -->
        <Border Grid.Row="0" 
                Background="#E8E8E8" 
                BorderBrush="#0066CC" 
                BorderThickness="0,0,0,2"
                Padding="10">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock FontFamily="Consolas" 
                           FontSize="10" 
                           Foreground="#0066CC"
                           TextAlignment="Center"
                           FontWeight="Bold">
                    <TextBlock.Text>
                        <![CDATA[
╔══════════════════════════════════════╗
║         CYBERSECURITY BOT            ║
╠══════════════════════════════════════╣
║    ╔══════╗     ╔══════╗            ║
║    ║  🔒  ║     ║  🛡️  ║            ║
║    ╚══════╝     ╚══════╝            ║
║         STAY SAFE ONLINE             ║
╚══════════════════════════════════════╝
                        ]]>
                    </TextBlock.Text>
                </TextBlock>

                <Border Background="#0066CC20" 
                        CornerRadius="10" 
                        Padding="8,3"
                        Margin="0,5,0,0"
                        HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#0066CC" Margin="0,0,5,0"/>
                        <TextBlock Text="READY" Foreground="#0066CC" FontSize="10" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Chat Messages Area -->
        <ListBox x:Name="MessagesListBox" 
                 Grid.Row="1" 
                 Background="#F0F0F0" 
                 BorderThickness="0"
                 Margin="10,10,10,10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Avatar -->
                        <Border Grid.Column="0" 
                                Width="35" Height="35" 
                                CornerRadius="17.5" 
                                Background="{Binding AvatarColor}"
                                Margin="0,0,10,0">
                            <TextBlock Text="{Binding AvatarIcon}" 
                                       FontSize="18" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Message Bubble -->
                        <Border Grid.Column="1" 
                                CornerRadius="10" 
                                Background="{Binding BubbleColor}"
                                Padding="10,8"
                                MaxWidth="450"
                                HorizontalAlignment="Left">
                            <StackPanel>
                                <TextBlock Text="{Binding SenderName}" 
                                           FontWeight="Bold" 
                                           Foreground="#666666" 
                                           FontSize="10"
                                           Margin="0,0,0,3"/>
                                <TextBlock Text="{Binding Text}" 
                                           Foreground="{Binding TextColor}" 
                                           TextWrapping="Wrap"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm'}" 
                                           Foreground="#888888" 
                                           FontSize="9" 
                                           HorizontalAlignment="Right"
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Typing Indicator -->
        <Border x:Name="TypingIndicator" 
                Grid.Row="2" 
                Background="#E8E8E8" 
                CornerRadius="15" 
                Padding="10,5"
                Margin="10,0,0,94"
                Visibility="Collapsed"
                HorizontalAlignment="Left" Grid.RowSpan="2" Width="0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🤖" FontSize="12" Margin="0,0,5,0"/>
                <TextBlock x:Name="TypingText" Text="Bot is typing" Foreground="#0066CC" FontSize="11"/>
            </StackPanel>
        </Border>

        <!-- Input Area -->
        <Border Grid.Row="3" 
                Background="#E8E8E8" 
                BorderBrush="#CCCCCC" 
                BorderThickness="0,1,0,0"
                Padding="10" Margin="0,0,0,14" Grid.RowSpan="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
                           Text="YOUR MESSAGE:" 
                           Foreground="#0066CC" 
                           FontSize="11" 
                           FontWeight="Bold"
                           Margin="0,0,0,5"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="MessageTextBox" 
                             Grid.Column="0"
                             Background="#FFFFFF" 
                             Foreground="#000000"
                             SelectionBrush="#0066CC"
                             SelectionTextBrush="#FFFFFF"
                             CaretBrush="#000000"
                             BorderBrush="#0066CC"
                             BorderThickness="2"
                             FontSize="14"
                             FontWeight="Normal"
                             Padding="12,10"
                             MinHeight="50"
                             VerticalContentAlignment="Center"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             KeyDown="MessageTextBox_KeyDown"/>

                    <Button x:Name="SendButton" 
                            Grid.Column="1"
                            Content="SEND" 
                            Width="90" 
                            Height="50"
                            Margin="10,0,0,0"
                            Background="#0066CC"
                            Foreground="#FFFFFF"
                            FontWeight="Bold"
                            FontSize="12"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="SendButton_Click"/>
                </Grid>

                <TextBlock Grid.Row="2" 
                           Text="Click send to enter your respond." 
                           Foreground="#666666" 
                           FontSize="9"
                           Margin="0,8,0,0"/>
            </Grid>
        </Border>

        <StatusBar Grid.Row="4" Background="#E8E8E8" Padding="10,5" Margin="0,8,0,0">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="#0066CC" Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusText" Text="Online - Ready to help you stay safe" 
                               Foreground="#333333" FontSize="11"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>